YELP_API_KEY=
GOOGLE_MAPS_API_KEY=
# App profile mode: private | public
APP_PROFILE=private
# Client-visible profile mode (set same value as APP_PROFILE)
NEXT_PUBLIC_APP_PROFILE=private
# Optional: Yelp backfill attempts for Google-prominent rows in deployed env (default 30)
YELP_PROMINENT_LOOKUP_LIMIT_DEPLOYED=30
# Optional: delay between deployed backfill lookups in ms (default 350)
YELP_PROMINENT_BACKFILL_DELAY_MS_DEPLOYED=350
# Optional: cooldown before one retry on deployed Yelp 429 in ms (default 1500)
YELP_PROMINENT_RATE_LIMIT_RETRY_DELAY_MS_DEPLOYED=1500
# Optional: stop deployed backfill after this many consecutive 429 rows (default 8)
YELP_PROMINENT_MAX_CONSECUTIVE_429_DEPLOYED=8
# Public GA4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional: enables trusted internal server-side analytics event posting.
ANALYTICS_INTERNAL_KEY=
