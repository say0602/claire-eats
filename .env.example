YELP_API_KEY=
GOOGLE_MAPS_API_KEY=
# App profile mode: private | public
APP_PROFILE=private
# Client-visible profile mode (set same value as APP_PROFILE)
NEXT_PUBLIC_APP_PROFILE=private
# Optional: Yelp backfill attempts for Google-prominent rows in deployed env (default 30)
YELP_PROMINENT_LOOKUP_LIMIT_DEPLOYED=30
# Optional: extra cap for Yelp backfill attempts in public profile (default: no additional cap)
YELP_PROMINENT_LOOKUP_LIMIT_PUBLIC=
# Optional: delay between deployed backfill lookups in ms (default 700)
YELP_PROMINENT_BACKFILL_DELAY_MS_DEPLOYED=700
# Optional: cooldown before one retry on deployed Yelp 429 in ms (default 2500)
YELP_PROMINENT_RATE_LIMIT_RETRY_DELAY_MS_DEPLOYED=2500
# Optional: stop deployed backfill after this many consecutive 429 rows (default 20)
YELP_PROMINENT_MAX_CONSECUTIVE_429_DEPLOYED=20
# Optional: total budget for Yelp backfill loop per request in ms (default 30000)
YELP_PROMINENT_BACKFILL_BUDGET_MS=30000
# Optional: enable dynamic non-top-city cache path (default true, test defaults to off unless set)
SEARCH_DYNAMIC_CITY_CACHE_ENABLED=1
# Optional: cache key version for non-top-city dynamic cache
SEARCH_DYNAMIC_CITY_CACHE_VERSION=phase-h-v1
# Optional: cold-cache TTL in minutes for non-top-city dynamic cache
SEARCH_DYNAMIC_CITY_CACHE_TTL_COLD_MINUTES=20
# Optional: hot-cache TTL in minutes for non-top-city dynamic cache
SEARCH_DYNAMIC_CITY_CACHE_TTL_HOT_MINUTES=60
# Optional: cache-hit threshold before using hot TTL
SEARCH_DYNAMIC_CITY_CACHE_HOT_HIT_THRESHOLD=3
# Optional: max in-memory entries for dynamic city cache (oldest/expired entries pruned)
SEARCH_DYNAMIC_CITY_CACHE_MAX_ENTRIES=200
# Optional: enable snapshot serve path for public profile (default true)
SEARCH_SNAPSHOT_PUBLIC_ENABLED=1
# Optional: snapshot version directory under data/precompute (default pilot-v1)
SEARCH_SNAPSHOT_VERSION=pilot-v1
# Optional: HTTP base URL used when runtime filesystem snapshot reads are unavailable.
# Expected layout: <base>/<version>/_run-summary.json and <base>/<version>/<city-slug>.csv
# Example for static assets shipped with this app: https://your-domain.com/precompute
SEARCH_SNAPSHOT_HTTP_BASE_URL=
# Optional: reject snapshots older than this age in minutes (default 1440)
SEARCH_SNAPSHOT_MAX_AGE_MINUTES=1440
# Optional: emit search diagnostics in non-development environments when set to 1
SEARCH_DIAGNOSTICS_ENABLED=
# Public GA4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional: enables trusted internal server-side analytics event posting.
ANALYTICS_INTERNAL_KEY=
